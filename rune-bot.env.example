# /root/rune-bot/.env に配置する設定ファイル（例）
# このファイルをVPSの /root/rune-bot/.env にコピーして値を入力してください

# ── Anthropic API ──
ANTHROPIC_API_KEY=

# ── IMAPメール設定（Xserver） ──
IMAP_HOST=sv****.xserver.jp
IMAP_PORT=993
IMAP_USER=メールアドレス@ドメイン.com
IMAP_PASS=メールパスワード

# ── 管理システム ──
SYSTEM_URL=https://xxxxxx.com
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
LOGIN_ID=
LOGIN_PASS=

# ── LINE Notify ──
# https://notify-bot.line.me/my/ でトークンを発行
LINE_NOTIFY_TOKEN=
