# システム設定
SYSTEM_URL=（システムのURLを入力）
BASIC_AUTH_ID=（ベーシック認証IDを入力）
BASIC_AUTH_PASS=（ベーシック認証パスワードを入力）
SYSTEM_LOGIN_ID=（ログインIDを入力）
SYSTEM_LOGIN_PASS=（ログインパスワードを入力）

# LINE設定（各自取得）
LINE_CHANNEL_SECRET=（LINEチャンネルシークレットを入力）
LINE_CHANNEL_ACCESS_TOKEN=（LINEアクセストークンを入力）

# Anthropic API（各自取得）
ANTHROPIC_API_KEY=（APIキーを入力）

# IMAP設定（入金処理用）
IMAP_HOST=（IMAPホストを入力）
IMAP_PORT=993
IMAP_USER=（メールアドレスを入力）
IMAP_PASS=（メールパスワードを入力）

# 動作設定
DRY_RUN=true
DISABLE_STOP_TIME=false
SUPPORT_CHECK_TEST_MODE=false
